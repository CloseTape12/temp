local selectedInvItem = nil
local sendQueue = {}
local lastInventoryHash = ""

local function getQueuedCount(itemKey)
    for _, qItem in ipairs(sendQueue) do
        if qItem.ItemKey == itemKey then return qItem.Count end
    end
    return 0
end

local function refreshInventoryUI()
    for _, child in ipairs(InvScroller:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local items = getAllInventoryItems()
    local searchText = string.lower(SearchBox.Text or "")
    
    for itemKey, data in pairs(items) do
        if searchText == "" or string.find(string.lower(data.DisplayName), searchText, 1, true) then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 30)
            btn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 11
            
            local remaining = data.TotalCount - getQueuedCount(itemKey)
            btn.Text = string.format("%s (%d)", data.DisplayName, remaining)
            btn.Parent = InvScroller
            
            if selectedInvItem and selectedInvItem.ItemKey == itemKey then
                btn.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
            end
            
            btn.MouseButton1Click:Connect(function()
                selectedInvItem = data
                AmountBox.Text = tostring(data.TotalCount - getQueuedCount(itemKey))
                refreshInventoryUI()
            end)
        end
    end
    InvScroller.CanvasSize = UDim2.new(0, 0, 0, InvLayout.AbsoluteContentSize.Y + 10)
end

local function refreshQueueUI()
    for _, child in ipairs(QueueScroller:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, qItem in ipairs(sendQueue) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 30)
        btn.BackgroundColor3 = Color3.fromRGB(90, 50, 50)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 11
        btn.Text = string.format("❌ %s x%d", qItem.DisplayName, qItem.Count)
        btn.Parent = QueueScroller
        
        btn.MouseButton1Click:Connect(function()
            for i, item in ipairs(sendQueue) do
                if item.ItemKey == qItem.ItemKey then
                    table.remove(sendQueue, i)
                    break
                end
            end
            refreshQueueUI()
            refreshInventoryUI()
        end)
    end
    QueueScroller.CanvasSize = UDim2.new(0, 0, 0, QueueLayout.AbsoluteContentSize.Y + 10)
end

AddQueueBtn.MouseButton1Click:Connect(function()
    if not selectedInvItem then
        StatusLabel.Text = "❌ Выберите предмет в инвентаре!"
        return
    end
    
    local amount = tonumber(AmountBox.Text)
    if not amount or amount <= 0 then
        StatusLabel.Text = "❌ Введите количество!"
        return
    end
    
    local maxAvailable = selectedInvItem.TotalCount - getQueuedCount(selectedInvItem.ItemKey)
    if amount > maxAvailable then amount = maxAvailable end
    
    if amount <= 0 then
        StatusLabel.Text = "❌ Нет больше предметов для добавления!"
        return
    end
    
    local found = false
    for _, qItem in ipairs(sendQueue) do
        if qItem.ItemKey == selectedInvItem.ItemKey then
            qItem.Count = qItem.Count + amount
            found = true
            break
        end
    end
    
    if not found then
        table.insert(sendQueue, {
            ItemKey = selectedInvItem.ItemKey,
            Category = selectedInvItem.Category,
            Count = amount,
            DisplayName = selectedInvItem.DisplayName
        })
    end
    
    StatusLabel.Text = string.format("✅ Добавлено в очередь: %s (%d)", selectedInvItem.DisplayName, amount)
    refreshQueueUI()
    refreshInventoryUI()
end)

SendAllBtn.MouseButton1Click:Connect(function()
    local recipientId = tonumber(IdBox.Text)
    if not recipientId then
        StatusLabel.Text = "❌ Ошибка: Неверный ID!"
        return
    end
    
    if #sendQueue == 0 then
        StatusLabel.Text = "❌ Очередь пуста!"
        return
    end
    
    StatusLabel.Text = "⏳ Отправка пакета..."
    
    local batch = {}
    for _, qItem in ipairs(sendQueue) do
        table.insert(batch, {
            ItemKey = qItem.ItemKey,
            Count = qItem.Count,
            Category = qItem.Category
        })
    end
    
    local success, err = pcall(function()
        MailboxSendBatch:Fire(recipientId, batch, "")
    end)
    
    if success then
        StatusLabel.Text = string.format("🎉 Отправлено %d типов предметов!", #batch)
        sendQueue = {}
        refreshQueueUI()
        refreshInventoryUI()
    else
        StatusLabel.Text = "❌ Ошибка отправки: " .. tostring(err)
    end
end)

