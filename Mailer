local function showNotification(text)
    task.spawn(function()
        local activeNotifs = NotifyGui:GetChildren()
        local yIndex = #activeNotifs
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 260, 0, 45)
        frame.Position = UDim2.new(1, 280, 1, -55 - (yIndex * 50))
        frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        frame.BackgroundTransparency = 1
        frame.BorderSizePixel = 0
        frame.Parent = NotifyGui
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, -15, 1, 0)
        textLabel.Position = UDim2.new(0, 15, 0, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 13
        textLabel.TextXAlignment = Enum.TextXAlignment.Left
        textLabel.TextTransparency = 1
        textLabel.Text = "📩 " .. text
        textLabel.Parent = frame
        local tweenIn = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -280, 1, -55 - (yIndex * 50)), BackgroundTransparency = 0.2})
        local tweenInText = TweenService:Create(textLabel, TweenInfo.new(0.3), {TextTransparency = 0})
        tweenIn:Play()
        tweenInText:Play()
        task.wait(3)
        local tweenOut = TweenService:Create(frame, TweenInfo.new(0.3), {Position = UDim2.new(1, 280, 1, -55 - (yIndex * 50)), BackgroundTransparency = 1})
        local tweenOutText = TweenService:Create(textLabel, TweenInfo.new(0.3), {TextTransparency = 1})
        tweenOut:Play()
        tweenOutText:Play()
        tweenOut.Completed:Wait()
        frame:Destroy()
    end)
end

