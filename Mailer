local function performPlayerSearch()
    local keyword = PlayerSearchBox.Text
    if keyword == "" then return end
    
    SearchStatusLabel.Text = "⏳ Поиск..."
    
    -- Очищаем старые результаты
    for _, child in ipairs(PlayerResultsScroller:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    -- Если ввели ID, просто подставляем его
    if tonumber(keyword) then
        IdBox.Text = keyword
        SearchStatusLabel.Text = "✅ ID подставлен!"
        return
    end

    local foundUsers = {}

    -- Пробуем сделать HTTP запрос к API Roblox (через RoProxy)
    local url = "https://users.roproxy.com/v1/users/search?keyword=" .. HttpService:UrlEncode(keyword) .. "&limit=10"
    local success, response = pcall(function()
        return HttpService:GetAsync(url)
    end)

    if success and response then
        local okDecode, data = pcall(function() return HttpService:JSONDecode(response) end)
        if okDecode and data and data.data then
            for _, user in ipairs(data.data) do
                table.insert(foundUsers, {Name = user.name, Id = user.id})
            end
        end
    end

    -- Если API поиска не сработало, пробуем точное совпадение
    if #foundUsers == 0 then
        local okExact, userId = pcall(function()
            return Players:GetUserIdFromNameAsync(keyword)
        end)
        if okExact and userId then
            table.insert(foundUsers, {Name = keyword, Id = userId})
        end
    end

    -- Заполняем список
    if #foundUsers > 0 then
        SearchStatusLabel.Text = "✅ Найдено: " .. #foundUsers
        for _, u in ipairs(foundUsers) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 40)
            btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 12
            btn.TextWrapped = true
            btn.Text = u.Name .. "\n[ID: " .. u.Id .. "]"
            btn.Parent = PlayerResultsScroller

            btn.MouseButton1Click:Connect(function()
                IdBox.Text = tostring(u.Id)
                SearchStatusLabel.Text = "✅ Выбран: " .. u.Name
            end)
        end
        PlayerResultsScroller.CanvasSize = UDim2.new(0, 0, 0, PlayerResultsLayout.AbsoluteContentSize.Y + 10)
    else
        SearchStatusLabel.Text = "❌ Игрок не найден"
    end
end

