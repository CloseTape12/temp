local function extractFruitName(fullName)
    return string.match(fullName, "^(.-) %[.*%]$") or fullName
end

local function capitalizeFirst(str)
    return str:sub(1, 1):upper() .. str:sub(2)
end

local function getMailCategory(tool)
    if tool:GetAttribute("PetId") then return "Pets" end
    if tool:GetAttribute("SeedTool") then return "Seeds" end
    if tool:GetAttribute("HarvestedFruit") or string.match(tool.Name, "%[.*%]") then return "Fruits" end
    
    local mainCat = tool:GetAttribute("MainCategory")
    if mainCat == "Gear" or mainCat == "Gears" then
        local specificAttr = "Sprinkler"
        if tool:GetAttribute("WateringCan") then specificAttr = "WateringCan"
        elseif tool:GetAttribute("Shovel") then specificAttr = "Shovel"
        elseif tool:GetAttribute("Trowel") then specificAttr = "Trowel"
        elseif tool:GetAttribute("Sign") then specificAttr = "Sign"
        elseif tool:GetAttribute("Wheelbarrow") then specificAttr = "Wheelbarrow"
        elseif tool:GetAttribute("Crowbar") then specificAttr = "Crowbar"
        elseif tool:GetAttribute("Ladder") then specificAttr = "Ladder"
        elseif tool:GetAttribute("Rake") then specificAttr = "Rake"
        elseif tool:GetAttribute("FreezeRay") then specificAttr = "FreezeRay"
        elseif tool:GetAttribute("PowerHose") then specificAttr = "PowerHose"
        elseif tool:GetAttribute("StrawberrySniper") then specificAttr = "StrawberrySniper"
        elseif tool:GetAttribute("GrapplingHook") then specificAttr = "GrapplingHook"
        end
        return specificAttr .. "s"
    end
    if mainCat then return capitalizeFirst(mainCat) .. "s" end
    return "Gears"
end

local function getAllInventoryItems()
    local groupedItems = {}
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return groupedItems end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local count = tonumber(tool:GetAttribute("Count"))
            if count == nil then count = 1 end 
            
            local cat = getMailCategory(tool)
            local itemKey = ""

            if cat == "Pets" then
                itemKey = tostring(tool:GetAttribute("PetId"))
                count = 1
            elseif cat == "Seeds" then
                itemKey = tostring(tool:GetAttribute("SeedTool"))
            elseif cat == "Fruits" then
                itemKey = extractFruitName(tool.Name)
                count = 1
            else
                itemKey = tool.Name
            end

            if itemKey ~= "" and count > 0 then
                if not groupedItems[itemKey] then
                    groupedItems[itemKey] = {
                        ItemKey = itemKey,
                        Category = cat,
                        TotalCount = 0,
                        DisplayName = tool.Name
                    }
                end
                groupedItems[itemKey].TotalCount = groupedItems[itemKey].TotalCount + count
            end
        end
    end
    return groupedItems
end

local function getInventoryHash()
    local items = getAllInventoryItems()
    local keys = {}
    for k in pairs(items) do table.insert(keys, k) end
    table.sort(keys)
    local hash = ""
    for _, key in ipairs(keys) do
        hash = hash .. key .. ":" .. items[key].TotalCount .. "|"
    end
    return hash
end

