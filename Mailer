local selectedItemData = nil
local lastInventoryHash = ""

local function refreshItems()
    for _, child in ipairs(Scroller:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local items = getAllInventoryItems()
    local searchText = string.lower(SearchBox.Text or "")
    
    for itemKey, data in pairs(items) do
        if searchText == "" or string.find(string.lower(itemKey), searchText, 1, true) then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 30)
            btn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 12
            btn.Text = string.format("%s (x%d) [%s]", itemKey, data.TotalCount, data.Category)
            btn.Parent = Scroller
            
            if selectedItemData and selectedItemData.ItemKey == itemKey then
                btn.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
            end
            
            btn.MouseButton1Click:Connect(function()
                selectedItemData = data
                for _, child in ipairs(Scroller:GetChildren()) do
                    if child:IsA("TextButton") then child.BackgroundColor3 = Color3.fromRGB(70, 70, 70) end
                end
                btn.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
                AmountBox.Text = tostring(data.TotalCount)
                StatusLabel.Text = "Выбран: " .. itemKey
                StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
            end)
        end
    end
    
    Scroller.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    refreshItems()
end)

SendButton.MouseButton1Click:Connect(function()
    local recipientId = tonumber(IdBox.Text)
    local amount = tonumber(AmountBox.Text)
    
    if not recipientId then
        StatusLabel.Text = "❌ Ошибка: Неверный ID!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    if not selectedItemData then
        StatusLabel.Text = "❌ Ошибка: Выберите предмет!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    if not amount or amount <= 0 then
        StatusLabel.Text = "❌ Ошибка: Введите количество!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    if amount > selectedItemData.TotalCount then
        amount = selectedItemData.TotalCount
        AmountBox.Text = tostring(amount)
    end
    
    StatusLabel.Text = "⏳ Отправка..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    local sent = sendSelectedItem(recipientId, selectedItemData.ItemKey, amount, selectedItemData.Category)
    
    StatusLabel.Text = string.format("✅ Отправлено: %d шт.", sent)
    StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    
    task.wait(1)
    selectedItemData = nil
    AmountBox.Text = "0"
    refreshItems()
end)

