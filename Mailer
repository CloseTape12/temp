-- ЛОГИКА ОБРАБОТКИ ПРЕДМЕТОВ (ОТПРАВКА)
-- ==========================================
local function pluralizeCategory(cat)
    local map = {
        Seed = "Seeds", Gear = "Gears", Fruit = "Fruits",
        Seeds = "Seeds", Gears = "Gears", Fruits = "Fruits"
    }
    return map[cat] or cat
end

local function extractFruitName(fullName)
    return string.match(fullName, "^(.-) %[.*%]$") or fullName
end

local function getAllInventoryItems()
    local groupedItems = {}
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return groupedItems end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local count = tonumber(tool:GetAttribute("Count")) or 0
            local cat = tostring(tool:GetAttribute("MainCategory") or tool:GetAttribute("Category") or "")
            local itemKey = tostring(tool:GetAttribute("SeedTool") or tool:GetAttribute("ItemKey") or "")

            if cat == "" and string.match(tool.Name, "%[.*%]") then
                cat = "Fruit"
                count = 1
                itemKey = extractFruitName(tool.Name)
            end

            if cat ~= "" and count > 0 then
                if itemKey == "" then itemKey = tool.Name end
                local finalCat = pluralizeCategory(cat)

                if not groupedItems[itemKey] then
                    groupedItems[itemKey] = {
                        ItemKey = itemKey,
                        Category = finalCat,
                        TotalCount = 0
                    }
                end
                groupedItems[itemKey].TotalCount = groupedItems[itemKey].TotalCount + count
            end
        end
    end
    return groupedItems
end

local function getInventoryHash()
    local items = getAllInventoryItems()
    local keys = {}
    for k in pairs(items) do table.insert(keys, k) end
    table.sort(keys)
    
    local hash = ""
    for _, key in ipairs(keys) do
        hash = hash .. key .. ":" .. items[key].TotalCount .. "|"
    end
    return hash
end

local function sendSelectedItem(recipientId, itemKey, amountToSend, category)
    local batch = {}
    local sent = 0
    
    for i = 1, amountToSend, MAX_ITEMS do
        local chunkSize = math.min(MAX_ITEMS, amountToSend - sent)
        table.insert(batch, {
            ItemKey = itemKey,
            Count = chunkSize,
            Category = category
        })
        
        MailboxSendBatch:Fire(recipientId, batch, "")
        sent = sent + chunkSize
        batch = {}
        
        if sent < amountToSend then
            task.wait(SEND_DELAY)
        end
    end
    return sent
end

