-- ЛОГИКА СБОРА ПОЧТЫ
-- ==========================================
local function getRecieveFrame()
    local gui = player:WaitForChild("PlayerGui"):FindFirstChild("MailboxUI")
    if gui then
        local frame = gui:FindFirstChild("Frame")
        if frame then
            return frame:FindFirstChild("RecieveFrame")
        end
    end
    return nil
end

local function claimMails()
    local recieveFrame = getRecieveFrame()
    if not recieveFrame then return end

    local children = recieveFrame:GetChildren()
    if #children == 0 then return end

    print("📬 Найдено писем в интерфейсе: " .. #children)

    for _, item in ipairs(children) do
        local mailId = string.match(item.Name, "Gift_(%d+:.+)")

        if mailId then
            print("🚀 Собираю письмо: " .. mailId)
            pcall(function()
                MailboxClaim:Fire(mailId)
            end)
            pcall(function() item:Destroy() end)
            task.wait(0.5)
        end
    end
end

