local function getRecieveFrame()
    local gui = PlayerGui:FindFirstChild("MailboxUI")
    if gui then
        local frame = gui:FindFirstChild("Frame")
        if frame then return frame:FindFirstChild("RecieveFrame") end
    end
    return nil
end

local function claimMails()
    local recieveFrame = getRecieveFrame()
    if not recieveFrame then return end
    for _, item in ipairs(recieveFrame:GetChildren()) do
        local mailId = string.match(item.Name, "Gift_(%d+:.+)")
        if mailId then
            local itemInfo = "Подарок"
            local longestText = ""
            for _, desc in ipairs(item:GetDescendants()) do
                if desc:IsA("TextLabel") and #desc.Text > #longestText then longestText = desc.Text end
            end
            if longestText ~= "" then itemInfo = longestText end
            local success = pcall(function() MailboxClaim:Fire(mailId) end)
            if success then showNotification(itemInfo) end
            pcall(function() item:Destroy() end)
            task.wait(0.5)
        end
    end
end

