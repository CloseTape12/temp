local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- 1. ТЕЛЕПОРТ В НАЧАЛО СКРИПТА
-- ==========================================
local function teleportToStart()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    
    local targetPart = Workspace:WaitForChild("Gardens"):WaitForChild("Plot1"):WaitForChild("Visual"):WaitForChild("PRIM")
    
    hrp.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
    print("Телепорт к Plot1 выполнен!")
end

teleportToStart()

-- ==========================================
-- 2. ОСНОВНАЯ ЛОГИКА (СБОР И ПРОДАЖА)
-- ==========================================
local Packet = require(ReplicatedStorage:WaitForChild("SharedModules"):WaitForChild("Packet"))
local CollectFruit = Packet("CollectFruit")
local SellAll = Packet("SellAll")

-- Функция для безопасного получения текущего количества плодов в инвентаре
local function getFruitCount()
    local success, result = pcall(function()
        return LocalPlayer.PlayerGui.BackpackGui.Backpack.Inventory.FruitInventory.Text
    end)
    
    if success and result then
        local countStr = string.match(result, "(%d+)")
        if countStr then
            return tonumber(countStr)
        end
    end
    return 0
end

local function getActiveFruits()
    local fruits = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "HarvestPrompt" and obj:IsA("ProximityPrompt") and obj.Enabled then
            local harvestPart = obj.Parent
            if harvestPart then
                local fruit = harvestPart.Parent
                if fruit then
                    table.insert(fruits, fruit)
                end
            end
        end
    end
    return fruits
end

local function parseUUIDs(fruitName)
    local parts = {}
    for part in string.gmatch(fruitName, "[^_]+") do
        table.insert(parts, part)
    end
    return parts[2], parts[3] or ""
end

print("Авто-сборщик запущен. Сканирование огорода...")

-- Настройки продажи
local SELL_INTERVAL = 5 -- Интервал продажи в секундах
local lastSellTime = 0  -- Время последней продажи

while true do
    -- 1. Проверяем инвентарь и продаём раз в 5 секунд
    local fruitCount = getFruitCount()
    local currentTime = os.clock()
    
    if fruitCount > 0 and (currentTime - lastSellTime >= SELL_INTERVAL) then
        print("Авто-продажа (раз в " .. SELL_INTERVAL .. " сек). В инвентаре: " .. fruitCount)
        SellAll:Fire()
        lastSellTime = currentTime -- Обновляем время продажи
        task.wait(1) -- Ждем 1 секунду, чтобы сервер обработал продажу и очистил инвентарь
    end

    -- 2. Сканируем и собираем плоды
    local fruits = getActiveFruits()
    local harvested = 0

    for _, fruit in ipairs(fruits) do
        local plantUUID, fruitUUID = parseUUIDs(fruit.Name)
        if plantUUID then
            CollectFruit:Fire(plantUUID, fruitUUID)
            harvested = harvested + 1
            task.wait(0.1)
        end
    end

    if harvested > 0 then
        print("Собрано за этот проход: " .. harvested)
    end

    -- Задержка между полными проверками огорода
    task.wait(1) 
end
