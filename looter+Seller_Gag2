local Packet = require(game:GetService("ReplicatedStorage"):WaitForChild("SharedModules"):WaitForChild("Packet"))
local CollectFruit = Packet("CollectFruit")
local SellAll = Packet("SellAll")
local player = game:GetService("Players").LocalPlayer

-- Кнопки GUI
local gardenBtn = player.PlayerGui:WaitForChild("TeleportButtons"):WaitForChild("TeleportButtons"):WaitForChild("GardenButton", 10)
local sellBtn = player.PlayerGui:WaitForChild("TeleportButtons"):WaitForChild("TeleportButtons"):WaitForChild("SellButton", 10)

if not gardenBtn or not sellBtn then
    warn("Не найдены обе кнопки телепорта!")
    return
end

-- Функции для сбора
local function getActiveFruits()
    local fruits = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "HarvestPrompt" and obj:IsA("ProximityPrompt") and obj.Enabled then
            local harvestPart = obj.Parent
            if harvestPart then
                local fruit = harvestPart.Parent
                if fruit then
                    table.insert(fruits, fruit)
                end
            end
        end
    end
    return fruits
end

local function parseUUIDs(fruitName)
    local parts = {}
    for part in string.gmatch(fruitName, "[^_]+") do
        table.insert(parts, part)
    end
    if #parts >= 3 then
        return parts[2], parts[3]
    end
    return nil, nil
end

-- === НАЧАЛО ЦИКЛА ===
while true do
    print("=== Начинаю цикл сбора ===")

    -- 1. Телепорт в сад
    firesignal(gardenBtn.Activated)
    print("Телепорт в сад...")
    task.wait(2)  -- время на загрузку грядок

    -- 2. Сбор фруктов
    local fruits = getActiveFruits()
    print("Найдено плодов: " .. #fruits)

    local harvested = 0
    for i, fruit in ipairs(fruits) do
        local plantUUID, fruitUUID = parseUUIDs(fruit.Name)
        if plantUUID and fruitUUID then
            print(string.format("[%d/%d] Собираю: %s", i, #fruits, fruitUUID))
            CollectFruit:Fire(plantUUID, fruitUUID)
            harvested = harvested + 1
            task.wait(0.15)
        end
    end
    print("Собрано: " .. harvested)

    -- 3. Телепорт к рынку и продажа
    firesignal(sellBtn.Activated)
    print("Телепорт к рынку...")
    task.wait(2)  -- время на перемещение

    print("Продаю всё...")
    SellAll:Fire()
    task.wait(1)  -- даём серверу обработать продажу

    print("Цикл завершён. Жду 5 минут до следующего сбора...")
    task.wait(300)  -- интервал между полными циклами (можно менять)
end
