local player = game:GetService("Players").LocalPlayer
local Packet = require(game:GetService("ReplicatedStorage"):WaitForChild("SharedModules"):WaitForChild("Packet"))
local MailboxClaim = Packet("MailboxClaim")

-- Хранилище уже обработанных ID, чтобы не дёргать сервер повторно
local processedGifts = {}

print("📬 Авто-приём почты запущен. Ожидаю открытия почтового ящика...")

while true do
    local mailboxUI = player.PlayerGui:FindFirstChild("MailboxUI")
    if mailboxUI then
        local recieveFrame = mailboxUI.Frame and mailboxUI.Frame:FindFirstChild("RecieveFrame")
        if recieveFrame then
            local newGifts = {}
            -- Собираем все актуальные Gift_ объекты
            for _, child in ipairs(recieveFrame:GetChildren()) do
                if child.Name:find("^Gift_") then
                    local giftId = child.Name:sub(6)
                    if giftId ~= "" and not processedGifts[giftId] then
                        table.insert(newGifts, giftId)
                    end
                end
            end

            -- Забираем каждую новую посылку
            for _, giftId in ipairs(newGifts) do
                print("📬 Забираю посылку: " .. giftId)
                MailboxClaim:Fire(giftId)
                processedGifts[giftId] = true
                task.wait(0.5) -- небольшая пауза, чтобы не заспамить
            end

            if #newGifts == 0 then
                -- Если новых посылок нет, просто ждём (окно открыто, может появятся позже)
                task.wait(1)
            end
        else
            task.wait(0.2) -- RecieveFrame ещё не загрузился
        end
    else
        -- Окно почты закрыто, ждём открытия
        task.wait(1)
    end
end
